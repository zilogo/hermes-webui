#!/bin/zsh
# Single source of truth for host deployments.
# Copy to: ~/.config/karmabox_pro/env.sh

export HERMES_HOME="$HOME/.karmabox_pro"
export HERMES_BASE_HOME="$HOME/.karmabox_pro"
export HERMES_CONFIG_PATH="$HOME/.karmabox_pro/config.yaml"
export HERMES_WEBUI_STATE_DIR="$HOME/.karmabox_pro/webui"

# Adjust these two paths per machine.
export HERMES_WEBUI_AGENT_DIR="$HOME/Projects/companion/hermes-agents/hermes-agent"
export HERMES_WEBUI_DIR="$HOME/Projects/companion/hermes-agents/hermes-webui"
export HERMES_WEBUI_PYTHON="$HOME/Projects/companion/hermes-agents/hermes-agent/.venv/bin/python"

# Optional WebUI defaults
export HERMES_WEBUI_HOST="127.0.0.1"
export HERMES_WEBUI_PORT="8791"
