# Copy to: ~/.config/karmabox_pro/env.systemd
# Used by systemd EnvironmentFile=

HERMES_HOME=/home/YOUR_USER/.karmabox_pro
HERMES_BASE_HOME=/home/YOUR_USER/.karmabox_pro
HERMES_CONFIG_PATH=/home/YOUR_USER/.karmabox_pro/config.yaml
HERMES_WEBUI_STATE_DIR=/home/YOUR_USER/.karmabox_pro/webui

HERMES_WEBUI_AGENT_DIR=/opt/hermes/hermes-agent
HERMES_WEBUI_DIR=/opt/hermes/hermes-webui
HERMES_WEBUI_PYTHON=/opt/hermes/hermes-agent/.venv/bin/python

HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_PORT=8791
